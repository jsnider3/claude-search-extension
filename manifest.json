{
  "manifest_version": 3,
  "name": "Claude Search",
  "version": "1.0.0",
  "description": "Use Claude.ai as your default search engine. Type 'cl' in the address bar followed by your query.",
  "permissions": ["clipboardWrite", "clipboardRead", "storage"],
  "options_page": "options.html",
  "omnibox": {
    "keyword": "cl"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
